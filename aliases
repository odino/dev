push (){
  git push --set-upstream origin `git symbolic-ref --short HEAD`
}

merge (){
	git merge --no-ff --no-edit "$@"
}
## rebase a specific git branch
## from master
rebase (){
    ck "$@" && git pull --rebase && master && git pull --rebase && ck "$@" && rebm
}

